ENV=development
DATABASE_URL=sqlite+aiosqlite:///./medevak.db
SECRET_KEY=dev-secret-change-in-production-medevak-2024
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=INFO
STRUCTURED_LOGGING=true
DEV_AUTH_BYPASS=true
PRIVATE_NETWORK_ONLY=true
ALLOW_GPS=false
CASES_CREATE_RATE_LIMIT=120/minute
DOCUMENTS_UPLOAD_RATE_LIMIT=30/minute
MAX_UPLOAD_SIZE=10485760
